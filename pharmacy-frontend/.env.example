# رابط الموقع العلني (لـ Open Graph و canonical عند المشاركة). مثال الإنتاج:
# VITE_PUBLIC_SITE_URL=https://pharmacy-frontend-psi.vercel.app

# عنوان الـ API (Laravel على Render) بدون / في النهاية — الكود يضيف /api/ تلقائياً (انظر src/Api/Api.jsx)
# محلياً:
VITE_API_BASE_URL=http://127.0.0.1:8000
# على Vercel: Settings → Environment Variables → VITE_API_BASE_URL = https://your-api.onrender.com
# ثم أعد نشر (Redeploy) بعد تغيير المتغير

# true = تفاصيل إضافية في Console لكل طلب/استجابة (اختياري؛ الإنتاج يعرض دائماً سطر [→] + أخطاء + /health)
# VITE_DEBUG_CONSOLE=true
